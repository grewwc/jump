{
  "name": "jump-history",
  "displayName": "Jump History",
  "description": "Track and revisit your navigation history across files",
  "version": "0.1.0",
  "publisher": "jump-history",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "repository": {
    "type": "git",
    "url": "https://github.com/local/jump-history"
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jump-history",
          "title": "Jump History",
          "icon": "media/history.svg"
        }
      ]
    },
    "views": {
      "jump-history": [
        {
          "id": "jumpHistoryChat",
          "name": "AI Chat",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "jumpHistoryTree",
          "name": "Jump History",
          "icon": "media/history.svg",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "jumpHistory.clearHistory",
        "title": "Clear History (Keep Pinned)",
        "category": "Jump History",
        "icon": "$(clear-all)"
      },
      {
        "command": "jumpHistory.clearAll",
        "title": "Clear All History (Including Pinned)",
        "category": "Jump History",
        "icon": "$(trash)"
      },
      {
        "command": "jumpHistory.removeDeleted",
        "title": "Remove Entries for Deleted Files",
        "category": "Jump History",
        "icon": "$(warning)"
      },
      {
        "command": "jumpHistory.deleteEntry",
        "title": "Delete Entry",
        "category": "Jump History",
        "icon": "$(close)"
      },
      {
        "command": "jumpHistory.deleteSelected",
        "title": "Delete Selected Entries",
        "category": "Jump History",
        "icon": "$(close)"
      },
      {
        "command": "jumpHistory.pinEntry",
        "title": "Pin Entry",
        "category": "Jump History",
        "icon": "$(pin)"
      },
      {
        "command": "jumpHistory.unpinEntry",
        "title": "Unpin Entry",
        "category": "Jump History",
        "icon": "$(pinned)"
      },
      {
        "command": "jumpHistory.copyPath",
        "title": "Copy File Path",
        "category": "Jump History",
        "icon": "$(copy)"
      },
      {
        "command": "jumpHistory.jumpToPrevious",
        "title": "Jump To Previous",
        "category": "Jump History",
        "icon": "$(arrow-up)"
      },
      {
        "command": "jumpHistory.jumpToNext",
        "title": "Jump To Next",
        "category": "Jump History",
        "icon": "$(arrow-down)"
      },
      {
        "command": "jumpHistory.deleteFileGroup",
        "title": "Remove All Entries for This File",
        "category": "Jump History"
      },
      {
        "command": "jumpHistory.toggleGroupByFile",
        "title": "Toggle Group by File",
        "category": "Jump History",
        "icon": "$(list-tree)"
      },
      {
        "command": "jumpHistory.refresh",
        "title": "Refresh",
        "category": "Jump History",
        "icon": "$(refresh)"
      },
      {
        "command": "jumpHistory.search",
        "title": "Search Jump History",
        "category": "Jump History",
        "icon": "$(search)"
      },
      {
        "command": "jumpHistory.clearSearch",
        "title": "Clear Search",
        "category": "Jump History",
        "icon": "$(close)"
      },
      {
        "command": "jumpHistory.changePinnedSort",
        "title": "Change Pinned Sort",
        "category": "Jump History",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "jumpHistory.newChat",
        "title": "New Chat Session",
        "category": "Jump History",
        "icon": "$(add)"
      },
      {
        "command": "jumpHistory.chatAddFile",
        "title": "Add Current File to Chat",
        "category": "Jump History",
        "icon": "$(file-add)"
      },
      {
        "command": "jumpHistory.switchChatSession",
        "title": "Switch Chat Session",
        "category": "Jump History",
        "icon": "$(history)"
      },
      {
        "command": "jumpHistory.renameChatSession",
        "title": "Rename Chat Session",
        "category": "Jump History",
        "icon": "$(edit)"
      },
      {
        "command": "jumpHistory.deleteChatSession",
        "title": "Delete Chat Session",
        "category": "Jump History",
        "icon": "$(trash)"
      },
      {
        "command": "jumpHistory.chatSendMessage",
        "title": "Send Chat Message",
        "category": "Jump History"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jumpHistory.search",
          "when": "view == jumpHistoryTree",
          "group": "navigation@0"
        },
        {
          "command": "jumpHistory.clearSearch",
          "when": "view == jumpHistoryTree",
          "group": "navigation@0.5"
        },
        {
          "command": "jumpHistory.toggleGroupByFile",
          "when": "view == jumpHistoryTree",
          "group": "navigation@1"
        },
        {
          "command": "jumpHistory.changePinnedSort",
          "when": "view == jumpHistoryTree",
          "group": "navigation@1.5"
        },
        {
          "command": "jumpHistory.removeDeleted",
          "when": "view == jumpHistoryTree",
          "group": "navigation@2"
        },
        {
          "command": "jumpHistory.clearHistory",
          "when": "view == jumpHistoryTree",
          "group": "navigation@3"
        },
        {
          "command": "jumpHistory.switchChatSession",
          "when": "view == jumpHistoryChat",
          "group": "navigation@0"
        },
        {
          "command": "jumpHistory.newChat",
          "when": "view == jumpHistoryChat",
          "group": "navigation@1"
        },
        {
          "command": "jumpHistory.renameChatSession",
          "when": "view == jumpHistoryChat",
          "group": "navigation@2"
        },
        {
          "command": "jumpHistory.deleteChatSession",
          "when": "view == jumpHistoryChat",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "jumpHistory.pinEntry",
          "when": "view == jumpHistoryTree && (viewItem == entry || viewItem == hotSpotEntry)",
          "group": "1_pin@1"
        },
        {
          "command": "jumpHistory.unpinEntry",
          "when": "view == jumpHistoryTree && (viewItem == entryPinned || viewItem == hotSpotEntry)",
          "group": "1_pin@2"
        },
        {
          "command": "jumpHistory.deleteEntry",
          "when": "view == jumpHistoryTree && (viewItem == entry || viewItem == entryPinned || viewItem == entryDeleted || viewItem == hotSpotEntry)",
          "group": "2_modify@1"
        },
        {
          "command": "jumpHistory.copyPath",
          "when": "view == jumpHistoryTree && (viewItem == entry || viewItem == entryPinned || viewItem == entryDeleted || viewItem == hotSpotEntry)",
          "group": "3_copy@1"
        },
        {
          "command": "jumpHistory.jumpToPrevious",
          "when": "view == jumpHistoryTree && (viewItem == entry || viewItem == entryPinned || viewItem == entryDeleted || viewItem == hotSpotEntry)",
          "group": "4_nav@1"
        },
        {
          "command": "jumpHistory.jumpToNext",
          "when": "view == jumpHistoryTree && (viewItem == entry || viewItem == entryPinned || viewItem == entryDeleted || viewItem == hotSpotEntry)",
          "group": "4_nav@2"
        },
        {
          "command": "jumpHistory.deleteFileGroup",
          "when": "view == jumpHistoryTree && viewItem == fileGroup",
          "group": "2_modify@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jumpHistory.chatSendMessage",
        "key": "cmd+enter",
        "when": "jumpHistory.chatInputFocused"
      },
      {
        "command": "jumpHistory.chatSendMessage",
        "key": "shift+enter",
        "when": "jumpHistory.chatInputFocused"
      },
      {
        "command": "jumpHistory.chatSendMessage",
        "key": "ctrl+enter",
        "when": "jumpHistory.chatInputFocused"
      },
      {
        "command": "jumpHistory.deleteSelected",
        "key": "delete",
        "mac": "backspace",
        "when": "focusedView == jumpHistoryTree && listFocus"
      },
      {
        "command": "jumpHistory.search",
        "key": "cmd+f",
        "when": "focusedView == jumpHistoryTree && listFocus"
      },
      {
        "command": "jumpHistory.search",
        "key": "ctrl+f",
        "when": "focusedView == jumpHistoryTree && listFocus"
      },
      {
        "command": "workbench.action.toggleSidebarVisibility",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "sideBarVisible && activeViewlet == 'workbench.view.extension.jump-history'"
      },
      {
        "command": "workbench.view.extension.jump-history",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "!sideBarVisible || activeViewlet != 'workbench.view.extension.jump-history'"
      }
    ],
    "configuration": {
      "title": "Jump History",
      "properties": {
        "jumpHistory.maxEntries": {
          "type": "number",
          "default": 500,
          "minimum": 10,
          "maximum": 5000,
          "description": "Maximum number of jump entries to keep in history"
        },
        "jumpHistory.lineJumpThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Minimum line distance to count as a meaningful in-file jump"
        },
        "jumpHistory.groupByFile": {
          "type": "boolean",
          "default": true,
          "description": "Group jump entries by file in the tree view"
        },
        "jumpHistory.pinnedSortOrder": {
          "type": "string",
          "enum": ["addedAt", "alphabetical"],
          "default": "addedAt",
          "description": "Sort order for the Pinned section"
        },
        "jumpHistory.showHotSpots": {
          "type": "boolean",
          "default": true,
          "description": "Show a 'Hot Spots' section at the top of the tree with most-visited locations"
        },
        "jumpHistory.hotSpotsCount": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of hot spots to display"
        },
        "jumpHistory.hotSpotsMinVisits": {
          "type": "number",
          "default": 2,
          "minimum": 2,
          "description": "Minimum number of visits for a location to be considered a hot spot"
        },
        "jumpHistory.agentBinaryPath": {
          "type": "string",
          "default": "a",
          "description": "Path to the AI agent binary (e.g. 'a' or '/path/to/a')"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
